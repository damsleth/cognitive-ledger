#!/usr/bin/env -S deno run -A
/// <reference lib="deno.ns" />
/**
 * obsidian_import
 *
 * Opinionated, heuristic importer from an Obsidian vault (or any markdown tree)
 * into a Cognitive Ledger repo.
 *
 * Design goals:
 * - Non-destructive: Obsidian is source-of-truth; cognitive-ledger receives curated projections.
 * - Incremental: checkpointed state, resumable.
 * - High-signal only: extracts only durable items (prefs/decisions/concepts/open-loops).
 * - Grep-friendly outputs: atomic markdown notes + provenance blocks + timeline append.
 * - No LLM required: uses heuristics/regex; later you can plug in an LLM step.
 *
 * Usage:
 *   ./obsidian_import scan  <source-notes-root> [--out notes/08_indices/obsidian_scan.md]  # vaultRoot can be any folder
 *   ./obsidian_import apply <source-notes-root> [--max-files 50] [--max-notes 100] [--min-confidence 0.75]  # vaultRoot can be any folder
 *   ./obsidian_import resume
 *
 * Notes:
 * - This tool assumes it is run from anywhere; it will operate on the ledger_root.
 * - By default, ledger_root is <ledger-root>.
 */

import { walk } from "jsr:@std/fs@1/walk"
import { ensureDir } from "jsr:@std/fs@1/ensure-dir"
import { join, resolve, dirname, relative, SEPARATOR } from "jsr:@std/path@1"
import { encodeHex } from "jsr:@std/encoding@1/hex"

type Cmd = "scan" | "apply" | "resume" | "help"

type Source = "user" | "tool" | "assistant" | "inferred"

type ArtifactKind = "pref" | "fact" | "goal" | "concept" | "loop"

type Scope = "home" | "work" | "dev" | "personal" | "meta"

type Lang = "en" | "no" | "mixed"

interface ImportState {
  version: number
  ledger_root: string
  vault_root?: string
  last_run?: string // ISO
  processed_files: Record<string, { mtimeMs: number; size: number; hash: string }> // by abs path
  imported_keys: Record<string, { ts: string; note_path: string; origin: string }> // by stable key
}

interface ScanRow {
  path_abs: string
  path_rel: string
  mtimeMs: number
  size: number
  words: number
  headings: number
  tasks: number
  signal_score: number
  yield_hint: number
  scope: Scope
}

interface Candidate {
  kind: ArtifactKind
  statement: string
  context?: string
  confidence: number
  tags: string[]
}

interface Args {
  cmd: Cmd
  vaultRoot?: string
  ledgerRoot: string
  out?: string
  statePath: string
  logPath: string
  timelinePath: string
  maxFiles: number
  maxNotes: number
  minConfidence: number
  minScore: number
  maxScore: number
  noBucketCaps: boolean
  dryRun: boolean
  verbose: boolean
}

const DEFAULT_LEDGER_ROOT = resolve(Deno.env.get("HOME") ?? "~", "Code", "cog-led")

function die(msg: string, code = 1): never {
  console.error(msg)
  Deno.exit(code)
}

function nowIso(): string {
  return new Date().toISOString()
}

async function sha1(text: string): Promise<string> {
  const data = new TextEncoder().encode(text)
  const hashBuffer = await crypto.subtle.digest("SHA-1", data)
  return encodeHex(hashBuffer)
}

function slugify(input: string): string {
  return input
    .trim()
    .toLowerCase()
    .replace(/['"`]/g, "")
    .replace(/[^a-z0-9]+/g, "_")
    .replace(/^_+|_+$/g, "")
    .slice(0, 80) || "untitled"
}

function countWords(s: string): number {
  const m = s.trim().match(/\S+/g)
  return m ? m.length : 0
}

function inferScopeFromPath(p: string): Scope {
  // Deterministic path-based mapping for the user's vault layout.
  // Priority is explicit top-level buckets like 01-home, 02-work, 03-community, 04-dev.
  const parts = p.split(SEPARATOR).filter(Boolean).map((x) => x.toLowerCase())

  // Look for top-level bucket markers anywhere in the path.
  if (parts.includes("01-home") || parts.includes("home")) return "home"
  if (parts.includes("02-work") || parts.includes("work")) return "work"
  if (parts.includes("04-dev") || parts.includes("dev")) return "dev"

  // Community/volunteer bucket: treat as personal by default (can be changed later).
  if (parts.includes("03-community") || parts.includes("community") || parts.includes("volunteer") || parts.includes("redcross")) return "personal"

  // Meta / system buckets.
  if (parts.includes("91-opt") || parts.includes("opt") || parts.includes("meta") || parts.includes("system")) return "meta"

  // Journal/archive are personal.
  if (parts.includes("90-journal") || parts.includes("journal")) return "personal"
  if (parts.includes("92-archive") || parts.includes("archive")) return "personal"

  return "personal"
}

function isPromptFile(pathAbs: string): boolean {
  const p = pathAbs.replace(/\\/g, "/").toLowerCase()
  return p.includes("/prompts/") || p.includes("/copilot-custom-prompts/")
}

function isJournalArchive(pathAbs: string): boolean {
  const p = pathAbs.replace(/\\/g, "/").toLowerCase()
  return p.includes("/90-journal/archive/")
}

function isJournalFile(pathAbs: string): boolean {
  const p = pathAbs.replace(/\\/g, "/").toLowerCase()
  return p.includes("/90-journal/")
}

function isMeetingLike(pathAbs: string, content: string): boolean {
  const p = pathAbs.replace(/\\/g, "/").toLowerCase()
  if (/(meeting|meetings|mom|minutes-of-meeting|minutes|møte|mote|samtale|call|check-?in|1-1|1:1|one-on-one|standup|sync|retro|retrospective|status)/i.test(p)) return true
  return /^(#|##)\s*(meeting|mom|minutes of meeting|minutes-of-meeting|minutes|møte|1:1|one-on-one|standup|sync|retro|retrospective|agenda|participants|attendees|deltakere)\b/mi.test(content)
}

const STRATEGIC_VERB_EN = /(decide|design|investigate|figure out|revisit|plan|define|choose|evaluate|implement|prototype)/i
const STRATEGIC_VERB_NO = /(bestemme|designe|undersøke|finne ut|ta opp igjen|planlegge|definere|velge|evaluere|implementere|prototype)/i

const DECISION_SECTION_RE = /^\s*#+\s*(decision|decisions|avgjørelse|avgjørelser|outcome|conclusion)\b/i
const ACTION_SECTION_RE = /^\s*#+\s*(next steps|next actions|action items|actions|oppfølging|oppfolging|tiltak)\b/i
const CONCEPT_HEADING_RE_EN = /^#+\s*(?:Definition|Concept|Framework|Principle|Rule|Guideline|Pattern|Heuristic|Policy):\s*(.+)$/gmi
const CONCEPT_HEADING_RE_NO = /^#+\s*(?:Definisjon|Konsept|Rammeverk|Prinsipp|Regel|Retningslinje|Mønster|Heuristikk|Policy):\s*(.+)$/gmi
const MIN_DECISION_WORDS = 4
const MIN_ACTION_WORDS = 4

function loopHasStrongMarker(stmt: string): boolean {
  // Allow explicit markers or an obvious temporal anchor.
  return /(#openloop|#loop|@loop|@openloop)/i.test(stmt) ||
    /\b(20\d{2}-\d{2}-\d{2}|q[1-4]|uke\s?\d{1,2}|week\s?\d{1,2})\b/i.test(stmt)
}

function loopHasOwnershipSignal(stmt: string): boolean {
  return /\b(i will|i'll|i should|i need to|we will|we should|we need to|owner|assignee|responsible)\b/i.test(stmt) ||
    /\b(jeg skal|jeg vil|jeg må|vi skal|vi må|eier|ansvar|ansvarlig)\b/i.test(stmt)
}

function loopHasDecisionPendingSignal(stmt: string): boolean {
  return /\b(decide|decision|need to decide|open question|pending|tbd|unsure|not sure|to be decided)\b/i.test(stmt) ||
    /\b(må bestemme|avgjørelse|åpent spørsmål|uavklart|usikker|ikke sikker|må avklare)\b/i.test(stmt)
}

function hasStrategicVerb(stmt: string): boolean {
  return STRATEGIC_VERB_EN.test(stmt) || STRATEGIC_VERB_NO.test(stmt)
}

function modalLineLooksActionable(stmt: string): boolean {
  return /^(?:We should|We must|We aim to)\s+\w+\b(?:\s+\w+){1,}/i.test(stmt) ||
    /^(?:Vi bør|Vi må|Vi har som mål)\s+\w+\b(?:\s+\w+){1,}/i.test(stmt)
}

function inferLang(content: string): Lang {
  // Very lightweight heuristic; default to mixed if uncertain.
  const hasNo = /\b(og|ikke|jeg|du|vi|skal|med|uten|hvor|hva|hvis)\b/i.test(content)
  const hasEn = /\b(and|not|i|you|we|should|with|without|what|if)\b/i.test(content)
  if (hasNo && hasEn) return "mixed"
  if (hasNo) return "no"
  if (hasEn) return "en"
  return "mixed"
}

function countMatches(re: RegExp, content: string): number {
  const m = content.match(re)
  return m ? m.length : 0
}

function extractSectionItems(content: string, headingRe: RegExp): string[] {
  const lines = content.split(/\r?\n/)
  const out: string[] = []
  let active = false
  for (const raw of lines) {
    const line = raw.trimEnd()
    if (headingRe.test(line)) {
      active = true
      continue
    }
    if (/^\s*#+\s+/.test(line)) {
      active = false
      continue
    }
    if (!active) continue

    const task = line.match(/^\s*[-*+]\s*\[\s*\]\s+(.+)$/)
    const bullet = line.match(/^\s*[-*+]\s+(.+)$/)
    const numbered = line.match(/^\s*\d+\.\s+(.+)$/)
    const stmt = (task ?? bullet ?? numbered)?.[1]?.trim()
    if (stmt) out.push(stmt)
  }
  return out
}

function yieldHint(content: string): number {
  const pref = countMatches(/^(?:-\s*)?(?:I prefer|I want you to|Going forward|From now on)\b/gmi, content) +
    countMatches(/^(?:-\s*)?(?:Jeg foretrekker|Jeg vil|Fremover|Fra nå av)\b/gmi, content)
  const decision = countMatches(/^(?:-\s*)?(?:Decision:|Decided:|We will|We should|We must|We aim to|I decided)\b/gmi, content) +
    countMatches(/^(?:-\s*)?(?:Avgjørelse:|Bestemt:|Vi skal|Vi bør|Vi må|Vi har som mål|Jeg bestemte)\b/gmi, content)
  const definition = countMatches(/^#+\s*(?:Definition|Concept|Framework|Principle|Rule|Guideline|Pattern|Heuristic|Policy):/gmi, content) +
    countMatches(/^#+\s*(?:Definisjon|Konsept|Rammeverk|Prinsipp|Regel|Retningslinje|Mønster|Heuristikk|Policy):/gmi, content)
  const decisionHeads = countMatches(/^\s*#+\s*(decision|decisions|avgjørelse|avgjørelser|outcome|conclusion)\b/gmi, content)
  const actionHeads = countMatches(/^\s*#+\s*(next steps|next actions|action items|actions|oppfølging|oppfolging|tiltak)\b/gmi, content)

  let strategicTasks = 0
  for (const m of content.matchAll(/^(?:-\s*)?\[\s*\]\s+(.+)$/gmi)) {
    const stmt = m[1].trim()
    if (STRATEGIC_VERB_EN.test(stmt) || STRATEGIC_VERB_NO.test(stmt)) strategicTasks++
  }

  let score = 0
  score += Math.min(3, pref) * 2
  score += Math.min(3, decision) * 2
  score += Math.min(3, definition) * 2
  score += Math.min(2, decisionHeads) * 1.5
  score += Math.min(2, actionHeads) * 1.0
  score += Math.min(5, strategicTasks) * 1.5
  return score
}

function parseArgs(argv: string[]): Args {
  // Check for help flags first
  if (argv.length === 0 || argv[0] === "-h" || argv[0] === "--help") {
    return {
      cmd: "help",
      vaultRoot: undefined,
      ledgerRoot: DEFAULT_LEDGER_ROOT,
      out: undefined,
      statePath: "",
      logPath: "",
      timelinePath: "",
      maxFiles: 50,
      maxNotes: 100,
      minConfidence: 0.75,
      minScore: 1.5,
      maxScore: 20.0,
      noBucketCaps: false,
      dryRun: false,
      verbose: false,
    }
  }

  const cmd = argv[0] as Cmd
  const vaultRoot = cmd === "scan" || cmd === "apply" ? argv[1] : undefined

  // defaults
  let ledgerRoot = DEFAULT_LEDGER_ROOT
  let out: string | undefined
  let maxFiles = 50
  let maxNotes = 100
  let minConfidence = 0.75
  let minScore = 1.5
  let maxScore = 20.0
  let noBucketCaps = false
  let dryRun = false
  let verbose = false

  // global flags after positional args
  const rest = argv.slice(cmd === "scan" || cmd === "apply" ? 2 : 1)
  for (let i = 0; i < rest.length; i++) {
    const a = rest[i]
    if (a === "--ledger-root") ledgerRoot = resolve(rest[++i] ?? die("Missing value for --ledger-root"))
    else if (a === "--out") out = rest[++i] ?? die("Missing value for --out")
    else if (a === "--max-files") maxFiles = Number(rest[++i] ?? die("Missing value for --max-files"))
    else if (a === "--max-notes") maxNotes = Number(rest[++i] ?? die("Missing value for --max-notes"))
    else if (a === "--min-confidence") minConfidence = Number(rest[++i] ?? die("Missing value for --min-confidence"))
    else if (a === "--min-score") minScore = Number(rest[++i] ?? die("Missing value for --min-score"))
    else if (a === "--max-score") maxScore = Number(rest[++i] ?? die("Missing value for --max-score"))
    else if (a === "--no-bucket-caps") noBucketCaps = true
    else if (a === "--dry-run") dryRun = true
    else if (a === "--verbose") verbose = true
    else if (a === "-h" || a === "--help") return {
      cmd: "help",
      vaultRoot,
      ledgerRoot,
      out,
      statePath: "",
      logPath: "",
      timelinePath: "",
      maxFiles,
      maxNotes,
      minConfidence,
      minScore,
      maxScore,
      noBucketCaps,
      dryRun,
      verbose,
    }
    else die(`Unknown argument: ${a}`)
  }

  const statePath = join(ledgerRoot, "notes", "08_indices", "obsidian_import_state.json")
  const logPath = join(ledgerRoot, "notes", "08_indices", "obsidian_import_log.md")
  const timelinePath = join(ledgerRoot, "notes", "08_indices", "timeline.md")

  return {
    cmd,
    vaultRoot: vaultRoot ? resolve(vaultRoot) : undefined,
    ledgerRoot,
    out,
    statePath,
    logPath,
    timelinePath,
    maxFiles,
    maxNotes,
    minConfidence,
    minScore,
    maxScore,
    noBucketCaps,
    dryRun,
    verbose,
  }
}

