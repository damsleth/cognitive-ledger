  console.log("DEPRECATED: use the Python CLI `ledger-obsidian` for new setups.")
  console.log("Example: pipx install cognitive-ledger && ledger-obsidian init --vault <path>")
  console.log("")
  console.log(`obsidian_import (Deno)

Usage:
  obsidian_import scan  <vaultRoot> [--out <path>] [--ledger-root <path>] [--verbose]
  obsidian_import apply <vaultRoot> [--max-files N] [--max-notes N] [--min-confidence X] [--min-score S] [--max-score S] [--no-bucket-caps] [--dry-run] [--ledger-root <path>] [--verbose]
  obsidian_import resume              [--max-files N] [--max-notes N] [--min-confidence X] [--min-score S] [--max-score S] [--no-bucket-caps] [--dry-run] [--ledger-root <path>] [--verbose]

Defaults:
  ledger_root: ${DEFAULT_LEDGER_ROOT}
  --max-files: 50
  --max-notes: 100
  --min-confidence: 0.75
  --min-score: 1.5
  --max-score: 20.0

Notes:
  - scan is read-only and produces a report.
  - apply/resume may write notes + indices + timeline unless --dry-run.
`)
}

async function readText(path: string): Promise<string> {
  return await Deno.readTextFile(path)
}

async function fileHash(path: string): Promise<string> {
  const data = await Deno.readFile(path)
  const hashBuffer = await crypto.subtle.digest("SHA-1", data)
  return encodeHex(hashBuffer)
}

async function loadState(args: Args): Promise<ImportState> {
  try {
    const raw = await readText(args.statePath)
    const s = JSON.parse(raw) as ImportState
    // basic sanity
    if (!s.processed_files) s.processed_files = {}
    if (!s.imported_keys) s.imported_keys = {}
    return s
  } catch {
    return {
      version: 1,
      ledger_root: args.ledgerRoot,
      processed_files: {},
      imported_keys: {},
    }
  }
}

async function saveState(args: Args, state: ImportState): Promise<void> {
  await ensureDir(dirname(args.statePath))
  await Deno.writeTextFile(args.statePath, JSON.stringify(state, null, 2) + "\n")
}

async function appendLog(args: Args, lines: string[]): Promise<void> {
  await ensureDir(dirname(args.logPath))
  const ts = nowIso()
  const block = [
    "\n---\n",
    `## ${ts}`,
    "",
    ...lines,
    "",
  ].join("\n")
  if (args.dryRun) return
  await Deno.writeTextFile(args.logPath, (await safeRead(args.logPath)) + block)
}

async function appendTimeline(args: Args, entries: string[]): Promise<void> {
  await ensureDir(dirname(args.timelinePath))
  const prefix = (await safeRead(args.timelinePath))
  const out = prefix + (prefix.endsWith("\n") ? "" : "\n") + entries.join("\n") + "\n"
  if (args.dryRun) return
  await Deno.writeTextFile(args.timelinePath, out)
}

async function safeRead(path: string): Promise<string> {
  try {
    return await Deno.readTextFile(path)
  } catch {
    return ""
  }
}

function scoreSignal(content: string): { headings: number; tasks: number; score: number } {
  const headings = (content.match(/^#+\s+/gm) ?? []).length
  const tasks = (content.match(/^\s*-\s*\[[ xX]\]\s+/gm) ?? []).length

  const strong = [
    /\b(i prefer|i want you to|going forward)\b/i,
    /\b(jeg foretrekker|jeg vil|fremover|fra nå av)\b/i,
    /\b(decided|decision|we will|commit to|rule:)\b/i,
    /\b(bestemt|besluttet|avgjort|avjørelse:|vi skal|forplikte|forpliktelse|regel:)\b/i,
    /\b(open question|revisit|not sure yet|need to decide)\b/i,
    /\b(åpent spørsmål|ta opp igjen|ikke sikker|må bestemme)\b/i,
    /\b(definition|means:|framework|concept)\b/i,
    /\b(definisjon|betyr:|rammeverk|konsept)\b/i,
  ]

  let score = headings * 0.2 + tasks * 0.1
  for (const r of strong) if (r.test(content)) score += 3

  // penalize very short notes (often ephemeral)
  const words = countWords(content)
  if (words < 40) score -= 1

  return { headings, tasks, score }
}

function extractCandidates(content: string): Candidate[] {
  const c: Candidate[] = []

  // Preferences (durable, first-person, instruction to assistant)
  for (const m of content.matchAll(/^(?:-\s*)?(?:I prefer|I want you to|Going forward|From now on)\s+(.+)$/gmi)) {
    const stmt = m[0].replace(/^\s*-\s*/g, "").trim()
    c.push({ kind: "pref", statement: stmt, confidence: 0.8, tags: ["imported", "preference"] })
  }

  // Norwegian: keep it strict (first-person / policy), avoid polite UI strings
  for (const m of content.matchAll(/^(?:-\s*)?(?:Jeg foretrekker|Jeg vil|Fremover|Fra nå av)\s+(.+)$/gmi)) {
    const stmt = m[0].replace(/^\s*-\s*/g, "").trim()
    c.push({ kind: "pref", statement: stmt, confidence: 0.8, tags: ["imported", "preference"] })
  }

  // Decisions / commitments
  for (const m of content.matchAll(/^(?:-\s*)?(?:Decision:|Decided:|We will|I decided)\s+(.+)$/gmi)) {
    const stmt = m[0].replace(/^\s*-\s*/g, "").trim()
    if (countWords(stmt) < MIN_DECISION_WORDS) continue
    c.push({ kind: "fact", statement: stmt, confidence: 0.75, tags: ["imported", "decision"] })
  }
  for (const m of content.matchAll(/^(?:-\s*)?(?:We should|We must|We aim to)\s+(.+)$/gmi)) {
    const stmt = m[0].replace(/^\s*-\s*/g, "").trim()
    if (!modalLineLooksActionable(stmt)) continue
    if (countWords(stmt) < MIN_DECISION_WORDS) continue
    c.push({ kind: "fact", statement: stmt, confidence: 0.75, tags: ["imported", "decision"] })
  }
  for (const m of content.matchAll(/^(?:-\s*)?(?:Avgjørelse:|Bestemt:|Vi skal|Jeg bestemte)\s+(.+)$/gmi)) {
    const stmt = m[0].replace(/^\s*-\s*/g, "").trim()
    if (countWords(stmt) < MIN_DECISION_WORDS) continue
    c.push({ kind: "fact", statement: stmt, confidence: 0.75, tags: ["imported", "decision"] })
  }
  for (const m of content.matchAll(/^(?:-\s*)?(?:Vi bør|Vi må|Vi har som mål)\s+(.+)$/gmi)) {
    const stmt = m[0].replace(/^\s*-\s*/g, "").trim()
    if (!modalLineLooksActionable(stmt)) continue
    if (countWords(stmt) < MIN_DECISION_WORDS) continue
    c.push({ kind: "fact", statement: stmt, confidence: 0.75, tags: ["imported", "decision"] })
  }

  // Concepts (simple patterns)
  CONCEPT_HEADING_RE_EN.lastIndex = 0
  for (const m of content.matchAll(CONCEPT_HEADING_RE_EN)) {
    const title = m[1].trim()
    if (title.length >= 3) {
      c.push({ kind: "concept", statement: `Definition: ${title}`, confidence: 0.75, tags: ["imported", "concept"] })
    }
  }
  CONCEPT_HEADING_RE_NO.lastIndex = 0
  for (const m of content.matchAll(CONCEPT_HEADING_RE_NO)) {
    const title = m[1].trim()
    if (title.length >= 3) {
      c.push({ kind: "concept", statement: `Definisjon: ${title}`, confidence: 0.75, tags: ["imported", "concept"] })
    }
  }

  // Decision blocks: list items under decision headings
  for (const stmt of extractSectionItems(content, DECISION_SECTION_RE)) {
    if (countWords(stmt) < MIN_DECISION_WORDS) continue
    c.push({ kind: "fact", statement: stmt, confidence: 0.75, tags: ["imported", "decision"] })
  }

  // Action blocks: list items under action headings
  for (const stmt of extractSectionItems(content, ACTION_SECTION_RE)) {
    if (countWords(stmt) < MIN_ACTION_WORDS && !hasStrategicVerb(stmt)) continue
    c.push({ kind: "loop", statement: stmt, confidence: 0.75, tags: ["imported", "open_loop"] })
  }

  // Open loops: durable tasks/questions
  for (const m of content.matchAll(/^(?:-\s*)?\[\s*\]\s+(.+)$/gmi)) {
    const stmt = m[1].trim()
    // Heuristic: filter out trivial very short tasks
    if (stmt.length < 18) continue
    // Heuristic: prefer tasks that look strategic
    const looksStrategic = STRATEGIC_VERB_EN.test(stmt) || STRATEGIC_VERB_NO.test(stmt)
    if (!looksStrategic) continue
    c.push({ kind: "loop", statement: stmt, confidence: 0.75, tags: ["imported", "open_loop"] })
  }

  // De-dupe identical statements within a file
  const seen = new Set<string>()
  return c.filter((x) => {
    const k = `${x.kind}::${x.statement.toLowerCase()}`
    if (seen.has(k)) return false
    seen.add(k)
    return true
  })
}

function kindToFolder(kind: ArtifactKind): string {
  switch (kind) {
    case "pref": return "notes/03_preferences"
    case "fact": return "notes/02_facts"
    case "goal": return "notes/04_goals"
    case "concept": return "notes/06_concepts"
    case "loop": return "notes/05_open_loops"
  }
}

function kindToPrefix(kind: ArtifactKind): string {
  switch (kind) {
    case "pref": return "pref"
    case "fact": return "fact"
    case "goal": return "goal"
    case "concept": return "concept"
    case "loop": return "loop"
  }
}

function buildFrontmatter(opts: {
  created: string
  updated: string
  tags: string[]
  confidence: number
  source: Source
  scope: Scope
  lang: Lang
  status?: string
}): string {
  const tags = `[${opts.tags.map((t) => t.trim()).filter(Boolean).join(", ")}]`
  const lines: string[] = ["---", `created: ${opts.created}`, `updated: ${opts.updated}`, `tags: ${tags}`, `confidence: ${opts.confidence}`, `source: ${opts.source}`, `scope: ${opts.scope}`, `lang: ${opts.lang}`]
  if (opts.status) lines.push(`status: ${opts.status}`)
  lines.push("---")
  return lines.join("\n")
}

function noteBody(opts: {
  title: string
  statement: string
  originRel: string
  originHeading?: string
  importedTs: string
}): string {
  const origin = opts.originHeading ? `${opts.originRel}#${opts.originHeading}` : opts.originRel
  return [
    `# ${opts.title}`,
    "",
    "## Statement",
    opts.statement,
    "",
    "## Provenance",
    `Origin: ${origin}`,
    `Imported: ${opts.importedTs}`,
    "",
    "## Links",
    "- ",
    "",
  ].join("\n")
}

async function scanVault(args: Args, vaultRoot: string): Promise<ScanRow[]> {
  const rows: ScanRow[] = []
  for await (const e of walk(vaultRoot, {
    includeDirs: false,
    exts: [".md"],
    followSymlinks: false,
    skip: [
      /\/\.obsidian\//,
      /\/\.smart-env\//,
      /\/\.smartchats\//,
      /\/\.trash\//,
      /\/00-tmp\//,
      /\/91-opt\//,
      /\/91-opt\/attachments\//,
    ],
  })) {
    const st = await Deno.stat(e.path)
    const content = await readText(e.path)
    const { headings, tasks, score } = scoreSignal(content)
    const hint = yieldHint(content)
    rows.push({
      path_abs: e.path,
      path_rel: relative(vaultRoot, e.path),
      mtimeMs: st.mtime?.getTime() ?? 0,
      size: st.size,
      words: countWords(content),
      headings,
      tasks,
      signal_score: score,
      yield_hint: hint,
      scope: inferScopeFromPath(e.path),
    })
  }
  rows.sort((a, b) => (b.yield_hint - a.yield_hint) || (b.signal_score - a.signal_score))
  return rows
}

function scanReport(rows: ScanRow[], vaultRoot: string): string {
  const ts = nowIso()
  const byScope = new Map<Scope, number>()
  for (const r of rows) byScope.set(r.scope, (byScope.get(r.scope) ?? 0) + 1)

  const top = rows.slice(0, 50)

  const lines: string[] = []
  lines.push(`# Obsidian Scan Report`)
  lines.push("")
  lines.push(`- Scanned: ${rows.length} files`)
  lines.push(`- Vault: ${vaultRoot}`)
  lines.push(`- Generated: ${ts}`)
  lines.push("")
  lines.push("## Files by scope")
  for (const s of ["home", "work", "dev", "personal", "meta"] as Scope[]) {
    lines.push(`- ${s}: ${byScope.get(s) ?? 0}`)
  }
  lines.push("")
  lines.push("## Top candidates (by yield hint, then signal score)")
  lines.push("Format: yield | score | scope | path | words | tasks | headings")
  for (const r of top) {
    lines.push(`- ${r.yield_hint.toFixed(2)} | ${r.signal_score.toFixed(2)} | ${r.scope} | ${r.path_rel} | ${r.words} | ${r.tasks} | ${r.headings}`)
  }
  lines.push("")
  lines.push("## Notes")
  lines.push("- This report does not write to the ledger.")
  lines.push("- Use `apply` to import high-signal items incrementally.")
  return lines.join("\n") + "\n"
}

async function writeNoteIfNew(args: Args, state: ImportState, vaultRoot: string, originAbs: string, candidate: Candidate, fileContent: string): Promise<{ created: boolean; noteRelPath: string } | null> {
  const originRel = relative(vaultRoot, originAbs)
  const importedTs = nowIso()

  const scope = inferScopeFromPath(originAbs)
  const lang = inferLang(fileContent)

  const keyBase = `${candidate.kind}|${scope}|${candidate.statement.trim().toLowerCase()}`
  const key = await sha1(keyBase)

  if (state.imported_keys[key]) {
    return null
  }

  const folderRel = kindToFolder(candidate.kind)
  const prefix = kindToPrefix(candidate.kind)
  const title = candidate.kind === "loop" ? `Loop: ${candidate.statement}` : candidate.statement
  const slug = slugify(candidate.statement)
  const filename = `${prefix}__${slug}.md`

  const noteAbsDir = join(args.ledgerRoot, folderRel)
  await ensureDir(noteAbsDir)

  const noteAbs = join(noteAbsDir, filename)
  const noteRelPath = join(folderRel, filename).replace(/\\/g, "/")

  const fm = buildFrontmatter({
    created: importedTs,
    updated: importedTs,
    tags: candidate.tags,
    confidence: candidate.confidence,
    source: "inferred",
    scope,
    lang,
    status: candidate.kind === "loop" ? "open" : undefined,
  })

  const body = noteBody({
    title: candidate.kind === "loop" ? `Loop: ${candidate.statement}` : candidate.statement,
    statement: candidate.statement,
    originRel: join(vaultRoot, originRel).replace(/\\/g, "/"),
    importedTs,
  })

  const full = `${fm}\n\n${body}`

  if (!args.dryRun) {
    // If file already exists, avoid overwriting; write a suffixed name.
    let target = noteAbs
    let targetRel = noteRelPath
    if (await exists(target)) {
      const suffix = (await sha1(importedTs)).slice(0, 6)
      target = join(noteAbsDir, `${prefix}__${slug}__${suffix}.md`)
      targetRel = join(folderRel, `${prefix}__${slug}__${suffix}.md`).replace(/\\/g, "/")
    }
    await Deno.writeTextFile(target, full)
    state.imported_keys[key] = { ts: importedTs, note_path: targetRel, origin: originRel }
    return { created: true, noteRelPath: targetRel }
  } else {
    // dry-run: pretend created
    state.imported_keys[key] = { ts: importedTs, note_path: noteRelPath, origin: originRel }
    return { created: true, noteRelPath: noteRelPath }
  }
}

async function exists(path: string): Promise<boolean> {
  try {
    await Deno.stat(path)
    return true
  } catch {
    return false
  }
}

async function applyImport(args: Args, state: ImportState, vaultRoot: string): Promise<void> {
  const rows = await scanVault(args, vaultRoot)

  // Only consider files with score >= minScore and with changes since last run.
  const candidates = rows.filter(
    (r) => r.signal_score >= args.minScore && r.signal_score <= args.maxScore,
  )

  // Prefer higher yield hints, then recency, then signal score to reduce 0-candidate files.
  candidates.sort((a, b) =>
    (b.yield_hint - a.yield_hint) ||
    (b.mtimeMs - a.mtimeMs) ||
    (b.signal_score - a.signal_score)
  )

  const selected: ScanRow[] = []

  // Prevent one subtree (especially journal archives) from dominating selection.
  const bucketCount = new Map<string, number>()
  const bucketCaps: Record<string, number> = args.noBucketCaps ? {} : {
    "journal-archive": 5,
    "journal": 20,
    // others are unlimited
  }

  function bucketOf(pathRel: string): string {
    const p = pathRel.replace(/\\/g, "/")
    if (p.startsWith("90-journal/archive/")) return "journal-archive"
    if (p.startsWith("90-journal/")) return "journal"
    if (p.startsWith("02-work/")) return "work"
    if (p.startsWith("04-dev/")) return "dev"
    if (p.startsWith("01-home/")) return "home"
    if (p.startsWith("03-community/")) return "community"
    if (p.startsWith("92-archive/")) return "archive"
    return "other"
  }

  for (const r of candidates) {
    if (selected.length >= args.maxFiles) break

    const b = bucketOf(r.path_rel)
    const n = bucketCount.get(b) ?? 0
    if (!args.noBucketCaps) {
      const cap = bucketCaps[b] ?? Number.POSITIVE_INFINITY
      if (n >= cap) continue
    }

    const abs = r.path_abs
    const st = await Deno.stat(abs)
    const hash = await fileHash(abs)

    const prev = state.processed_files[abs]
    if (prev && prev.hash === hash && prev.size === st.size) {
      continue // unchanged
    }

    selected.push(r)
    bucketCount.set(b, n + 1)
  }

  const createdNotes: { path: string; origin: string }[] = []
  const logLines: string[] = []

  let notesWritten = 0
  for (const r of selected) {
    if (notesWritten >= args.maxNotes) break

    const abs = r.path_abs
    const st = await Deno.stat(abs)
    const hash = await fileHash(abs)
    const content = await readText(abs)
    const processedRecord = { mtimeMs: st.mtime?.getTime() ?? 0, size: st.size, hash }

    let fileCandidates = extractCandidates(content)
      .filter((c) => c.confidence >= args.minConfidence)

    // Prompt/template files are meta-instructions; allow only concepts to be imported.
    if (isPromptFile(abs)) {
      fileCandidates = fileCandidates.filter((c) => c.kind === "concept")
    }

    // Journal archives are valuable but can contain very stale TODOs.
    // Allow loops only when explicitly marked or temporally anchored.
    if (isJournalArchive(abs)) {
      fileCandidates = fileCandidates.filter((c) => {
        if (c.kind !== "loop") return true
        return loopHasStrongMarker(c.statement)
      })
    }

    // For journals and meeting-like notes, require durable loop signals.
    if (isJournalFile(abs) || isMeetingLike(abs, content)) {
      fileCandidates = fileCandidates.filter((c) => {
        if (c.kind !== "loop") return true
        return loopHasOwnershipSignal(c.statement) || loopHasDecisionPendingSignal(c.statement)
      })
    }

    if (fileCandidates.length === 0) {
      state.processed_files[abs] = processedRecord
      continue
    }

    if (args.verbose) {
      console.log(
        `[file] ${r.path_rel} candidates=${fileCandidates.length} hint=${r.yield_hint.toFixed(2)} score=${r.signal_score.toFixed(2)} prompt=${isPromptFile(abs)}`,
      )
    }

    for (const cand of fileCandidates) {
      if (notesWritten >= args.maxNotes) break
      const res = await writeNoteIfNew(args, state, vaultRoot, abs, cand, content)
      if (!res) continue
      createdNotes.push({ path: res.noteRelPath, origin: r.path_rel })
      notesWritten++
    }

    state.processed_files[abs] = processedRecord
  }

  state.vault_root = vaultRoot
  state.last_run = nowIso()

  // Write state + logs
  const ts = nowIso()
  logLines.push(`- Vault: ${vaultRoot}`)
  logLines.push(`- Selected files: ${selected.length}`)
  logLines.push(`- Notes created: ${createdNotes.length}`)
  if (args.dryRun) logLines.push(`- Mode: dry-run (no files written)`)

  if (createdNotes.length > 0) {
    logLines.push("\n### Created notes")
    for (const n of createdNotes) logLines.push(`- ${n.path} (from ${n.origin})`)
  }

  // Timeline entries (only for created notes + state/log changes)
  const timeline: string[] = []
  for (const n of createdNotes) {
    timeline.push(`- ${ts} | created | ${n.path} | imported from Obsidian`)
  }

  if (!args.dryRun) {
    await saveState(args, state)
    await appendLog(args, logLines)
    if (timeline.length) await appendTimeline(args, timeline)
  } else {
    // In dry-run, still print summary
    console.log(logLines.join("\n"))
  }
}

async function main() {
  console.error("warning: obsidian_import is legacy. Prefer `ledger-obsidian` for new Obsidian integrations.")
  const args = parseArgs(Deno.args)
  if (args.cmd === "help" || args.cmd === undefined) {
    help()
    return
  }

  // Validate ledger root
  if (!(await exists(args.ledgerRoot))) {
    die(`Ledger root does not exist: ${args.ledgerRoot}\nUse --ledger-root to point to your cog-led repo.`)
  }

  const state = await loadState(args)

  if (args.cmd === "scan") {
    if (!args.vaultRoot) die("scan requires <vaultRoot>")
    const rows = await scanVault(args, args.vaultRoot)
    const report = scanReport(rows, args.vaultRoot)
    if (args.out) {
      const outAbs = resolve(args.ledgerRoot, args.out)
      await ensureDir(dirname(outAbs))
      await Deno.writeTextFile(outAbs, report)
      console.log(`Wrote scan report: ${outAbs}`)
    } else {
      console.log(report)
    }
    return
  }

  if (args.cmd === "apply") {
    if (!args.vaultRoot) die("apply requires <vaultRoot>")
    await applyImport(args, state, args.vaultRoot)
    return
  }

  if (args.cmd === "resume") {
    const vaultRoot = state.vault_root
    if (!vaultRoot) die("No vault_root in state. Run: obsidian_import apply <vaultRoot> first.")
    await applyImport(args, state, vaultRoot)
    return
  }

  die(`Unknown command: ${args.cmd}`)
}

await main()
