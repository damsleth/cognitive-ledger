def run_eval(
    cases_path,
    k,
    strict_cases=False,
    retrieval_mode="legacy",
    embed_backend="local",
    embed_model=None,
):
    return eval_lib.run_eval(
        cases_path=cases_path,
        k=k,
        strict_cases=strict_cases,
        retrieval_mode=retrieval_mode,
        embed_backend=embed_backend,
        embed_model=embed_model,
        rank_query_fn=rank_query,
    )


def maybe_log_query_telemetry(
    query,
    scope,
    retrieval_mode,
    payload,
    latency_ms,
    log_path=None,
):
    enabled = os.getenv("LEDGER_QUERY_LOG", "").strip().lower() in {"1", "true", "yes", "on"}
    if not enabled:
        return

    target_path = Path(log_path) if log_path else (ROOT_DIR / "notes" / "08_indices" / "query_log.jsonl")
    top_results = []
    for item in payload.get("results", [])[:3]:
        top_results.append(item.get("rel_path") or item.get("path", ""))

    record = {
        "ts": now_utc().strftime("%Y-%m-%dT%H:%M:%SZ"),
        "query": query,
        "scope": scope,
        "mode": payload.get("retrieval_mode", retrieval_mode),
        "top_3": top_results,
        "latency_ms": int(round(max(0.0, latency_ms))),
    }
    safe_append_line(target_path, json.dumps(record, ensure_ascii=False))


def handle_query_command(args):
    # Validate inputs at entry point
    try:
        validated_query = validate_query(args.text)
        validated_scope = validate_scope(args.scope)
        validated_limit = validate_limit(args.limit, min_val=1, max_val=1000)
    except QueryValidationError as e:
        print(f"error: {e.message}", file=sys.stderr)
        raise SystemExit(2)
    except ScopeValidationError as e:
        print(f"error: {e.message}", file=sys.stderr)
        raise SystemExit(2)
    except ValueError as e:
        print(f"error: {e}", file=sys.stderr)
        raise SystemExit(2)

    started = time.perf_counter()
    payload = rank_query(
        query=validated_query,
        scope=validated_scope,
        limit=validated_limit,
        aliases_path=ALIASES_PATH,
        retrieval_mode=args.retrieval_mode,
        embed_backend=args.embed_backend,
        embed_model=args.embed_model,
    )
    latency_ms = (time.perf_counter() - started) * 1000.0
    maybe_log_query_telemetry(
        query=validated_query,
        scope=validated_scope,
        retrieval_mode=args.retrieval_mode,
        payload=payload,
        latency_ms=latency_ms,
    )

    if args.json:
        out = {
            "query": payload["query"],
            "scope": payload["scope"],
            "retrieval_mode": payload.get("retrieval_mode", "legacy"),
            "effective_retrieval_mode": payload.get(
                "effective_retrieval_mode", payload.get("retrieval_mode", "legacy")
            ),
            "candidate_pool_size": payload.get("candidate_pool_size"),
            "indexed_pool_size": payload.get("indexed_pool_size"),
            "prefilter_size": payload.get("prefilter_size"),
            "shortlist_size": payload.get("shortlist_size"),
            "progressive_top_n": payload.get("progressive_top_n", 0),
            "expanded_tokens": payload["expanded_tokens"],
            "semantic": payload.get("semantic"),
            "results": [],
        }
        for item in payload["results"]:
            data = {
                "path": item["path"],
                "title": item["title"],
                "type": item["type"],
                "score": round(item["score"], 6),
                "reasons": item["reasons"],
                "updated": item["updated"],
                "confidence": item["confidence"],
                "source": item["source"],
                "scope": item["scope"],
            }
            if item["type"] == "loop":
                data["status"] = item.get("status", "")
            if item.get("disclosure_level"):
                data["disclosure_level"] = item.get("disclosure_level")
            out["results"].append(data)
        if args.bundle:
            out["bundle"] = bundle_results(payload["results"], word_budget=1200)
        print(json.dumps(out, indent=2, ensure_ascii=False))
        return

    print(format_query_results_human(payload, include_bundle=args.bundle))


def _print_embed_build_human(payload):
    print(f"target: {payload['target']}")
    print(f"backend: {payload['backend']}")
    print(f"model: {payload['model']}")
    for result in payload.get("results", []):
        print(
            "- "
            f"{result.get('target')} "
            f"items={result.get('item_count', 0)} "
            f"dims={result.get('dims', 0)} "
            f"embedded={result.get('embedded_count', 0)} "
            f"reused={result.get('reused_count', 0)} "
            f"removed={result.get('removed_count', 0)}"
        )


def handle_embed_build_command(args):
    embeddings = load_embeddings_module()
    model = args.model or embeddings.default_model_for_backend(args.backend)
    source_root = Path(args.source_root).expanduser().resolve()
    payload = embeddings.build_indices(
        target=args.target,
        backend=args.backend,
        model=model,
        source_root=source_root,
    )
    if args.json:
        print(json.dumps(payload, indent=2, ensure_ascii=False))
        return
    _print_embed_build_human(payload)


def handle_embed_status_command(args):
    embeddings = load_embeddings_module()
    payload = embeddings.index_status(target=args.target)
    if args.json:
        print(json.dumps(payload, indent=2, ensure_ascii=False))
        return

    print(f"target: {payload.get('target')}")
    for target_name, entries in payload.get("targets", {}).items():
        print(f"{target_name}:")
        if not entries:
            print("- none")
            continue
        for entry in entries:
            print(
                "- "
                f"{entry.get('backend','')}/{entry.get('model','')} "
                f"items={entry.get('item_count', 0)} "
                f"dims={entry.get('dims', 0)} "
                f"built_at={entry.get('built_at', '')}"
            )


def handle_embed_clean_command(args):
    embeddings = load_embeddings_module()
    payload = embeddings.clean_indices(target=args.target)
    if args.json:
        print(json.dumps(payload, indent=2, ensure_ascii=False))
        return
    print(f"target: {payload.get('target')}")
    removed = payload.get("removed", [])
    if not removed:
        print("removed: none")
        return
    for path in removed:
        print(f"- removed {path}")


def handle_discover_source_command(args):
    # Validate inputs at entry point
    try:
        validated_query = validate_query(args.text)
        validated_limit = validate_limit(args.limit, min_val=1, max_val=1000)
    except QueryValidationError as e:
        print(f"error: {e.message}", file=sys.stderr)
        raise SystemExit(2)
    except ValueError as e:
        print(f"error: {e}", file=sys.stderr)
        raise SystemExit(2)

    embeddings = load_embeddings_module()
    backend = resolve_embed_backend(args.embed_backend)
    model = resolve_embed_model(backend, args.embed_model)
    source_root = Path(args.source_root).expanduser().resolve()
    payload = embeddings.semantic_search(
        query=validated_query,
        target="source",
        backend=backend,
        model=model,
        limit=validated_limit,
        source_root=source_root,
        allow_api_on_source=args.allow_api_on_source,
    )

    if args.json:
        out = {
            "mode": "source_only",
            "target": payload.get("target", "source"),
            "backend": payload.get("backend", backend),
            "model": payload.get("model", model),
            "available": payload.get("available", False),
            "reason": payload.get("reason"),
            "results": [],
        }
        for item in payload.get("results", []):
            out["results"].append(
                {
                    "rel_path": item.get("rel_path", ""),
                    "abs_path": item.get("abs_path", ""),
                    "type": item.get("type", ""),
                    "scope": item.get("scope", ""),
                    "status": item.get("status", ""),
                    "lang": item.get("lang", ""),
                    "updated": item.get("updated", ""),
                    "cosine_similarity": round(float(item.get("cosine_similarity", 0.0)), 6),
                }
            )
        print(json.dumps(out, indent=2, ensure_ascii=False))
        return

    print("mode: source_only")
    print(f"backend: {payload.get('backend', backend)}")
    print(f"model: {payload.get('model', model)}")
    if not payload.get("available", False):
        print(f"available: no ({payload.get('reason', 'unknown')})")
        return
    print(f"results: {len(payload.get('results', []))}")
    for item in payload.get("results", []):
        print(
            "- "
            f"{item.get('cosine_similarity', 0.0):.3f} | "
            f"{item.get('rel_path', '')} | "
            f"{item.get('scope', '')}"
        )


def handle_eval_command(args):
    # Validate write-baseline path if provided
    if args.write_baseline:
        baseline_path = Path(args.write_baseline).resolve()
        # Check path is within repo or explicitly allowed
        try:
            baseline_path.relative_to(ROOT_DIR)
        except ValueError:
            print(
                f"error: --write-baseline path must be within repo root ({ROOT_DIR})",
                file=sys.stderr,
            )
            print("hint: use a path like 'notes/08_indices/baseline.json'", file=sys.stderr)
            raise SystemExit(2)

    try:
        backend = resolve_embed_backend(args.embed_backend)
        model = resolve_embed_model(backend, args.embed_model)
        result = run_eval(
            args.cases,
            k=args.k,
            strict_cases=args.strict_cases,
            retrieval_mode=args.retrieval_mode,
            embed_backend=backend,
            embed_model=model,
        )
    except EvalCaseValidationError as exc:
        print("eval_case_validation_errors:")
        for error in exc.errors:
            print(f"- {error}")
        raise SystemExit(2)
    print_eval_result(result)

    if args.baseline:
        cmp = compare_with_baseline(result, args.baseline)
        if not cmp["available"]:
            print(f"baseline: unavailable ({cmp['reason']})")
        else:
            print(
                "baseline_comparison: "
                f"hit@{result['k']} delta={cmp['hitk_delta']:+.3f}, "
                f"mrr delta={cmp['mrr_delta']:+.3f}, "
                f"regressed={'yes' if cmp['regressed'] else 'no'}"
            )
            if cmp["regressed"]:
                raise SystemExit(2)

    if args.write_baseline:
        snapshot = baseline_metrics(result)
        snapshot["generated_at"] = now_utc().strftime("%Y-%m-%dT%H:%M:%SZ")
        snapshot["cases_path"] = str(Path(args.cases).resolve())
        Path(args.write_baseline).write_text(json.dumps(snapshot, indent=2) + "\n", encoding="utf-8")
        print(f"baseline_written: {args.write_baseline}")


def main():
    parser = argparse.ArgumentParser(description="Cognitive Ledger retrieval helpers")
    subparsers = parser.add_subparsers(dest="command")

    loops_parser = subparsers.add_parser("loops", help="List loops (default: open)")
    loops_parser.add_argument("--limit", type=int, default=100)
    loops_parser.add_argument("--width", type=int, default=120)
    loops_parser.add_argument("--paths", action="store_true")
    loops_parser.add_argument("--status", choices=list(LOOP_STATUSES) + ["all"], default="open")
    loops_parser.add_argument("--verbose", action="store_true")
    loops_parser.add_argument("--interactive", action="store_true")

    notes_parser = subparsers.add_parser("notes", help="List notes by type")
    notes_parser.add_argument(
        "--type",
        required=True,
        choices=sorted(list(NOTE_TYPES.keys()) + ["all"]),
        help="Note type to list",
    )
    notes_parser.add_argument("--limit", type=int, default=100)
    notes_parser.add_argument("--width", type=int, default=120)
    notes_parser.add_argument("--paths", action="store_true")
    notes_parser.add_argument("--verbose", action="store_true")
    notes_parser.add_argument("--interactive", action="store_true")

    query_parser = subparsers.add_parser("query", help="Rank notes for a query")
    query_parser.add_argument("text", help="query text")
    query_parser.add_argument("--scope", choices=QUERY_SCOPES, default="all")
    query_parser.add_argument("--limit", type=int, default=8)
    query_parser.add_argument(
        "--retrieval-mode",
        choices=RETRIEVAL_MODES,
        default=resolve_retrieval_mode(None),
        help="Retrieval strategy (default: legacy; override with LEDGER_RETRIEVAL_MODE)",
    )
    query_parser.add_argument(
        "--embed-backend",
        choices=EMBED_BACKENDS,
        default=resolve_embed_backend(None),
        help="Embedding backend for semantic_hybrid mode (default: local)",
    )
    query_parser.add_argument(
        "--embed-model",
        default=None,
        help="Optional embedding model override for semantic_hybrid mode",
    )
    query_parser.add_argument("--json", action="store_true", dest="json")
    query_parser.add_argument("--bundle", action="store_true")

    discover_parser = subparsers.add_parser(
        "discover-source", help="Semantic discovery on source notes (source_only output)"
    )
    discover_parser.add_argument("text", help="query text")
    discover_parser.add_argument(
        "--source-root",
        default=str(Path.home() / "notes"),
        help="Source notes root for discovery (default: ~/notes)",
    )
    discover_parser.add_argument("--limit", type=int, default=20)
    discover_parser.add_argument(
        "--embed-backend",
        choices=EMBED_BACKENDS,
        default=resolve_embed_backend(None),
        help="Embedding backend for source discovery (default: local)",
    )
    discover_parser.add_argument(
        "--embed-model",
        default=None,
        help="Optional embedding model override",
    )
    discover_parser.add_argument(
        "--allow-api-on-source",
        action="store_true",
        help="Required with --embed-backend openai to allow source-note API externalization",
    )
    discover_parser.add_argument("--json", action="store_true", dest="json")

    embed_parser = subparsers.add_parser("embed", help="Build, inspect, or clean semantic indices")
    embed_subparsers = embed_parser.add_subparsers(dest="embed_command")

    embed_build_parser = embed_subparsers.add_parser("build", help="Build semantic indices")
    embed_build_parser.add_argument("--target", choices=("ledger", "source", "both"), required=True)
    embed_build_parser.add_argument("--backend", choices=EMBED_BACKENDS, required=True)
    embed_build_parser.add_argument("--model", default=None)
    embed_build_parser.add_argument(
        "--source-root",
        default=str(Path.home() / "notes"),
        help="Source notes root (used for target=source|both)",
    )
    embed_build_parser.add_argument("--json", action="store_true", dest="json")

    embed_status_parser = embed_subparsers.add_parser("status", help="Show semantic index status")
    embed_status_parser.add_argument("--target", choices=("ledger", "source", "both"), required=True)
    embed_status_parser.add_argument("--json", action="store_true", dest="json")

    embed_clean_parser = embed_subparsers.add_parser("clean", help="Clean semantic index artifacts")
    embed_clean_parser.add_argument("--target", choices=("ledger", "source", "both"), required=True)
    embed_clean_parser.add_argument("--json", action="store_true", dest="json")

    eval_parser = subparsers.add_parser("eval", help="Evaluate retrieval quality against benchmark cases")
    eval_parser.add_argument("--cases", required=True, help="Path to retrieval_eval_cases.yaml")
    eval_parser.add_argument("--k", type=int, default=3)
    eval_parser.add_argument(
        "--retrieval-mode",
        choices=RETRIEVAL_MODES,
        default=resolve_retrieval_mode(None),
        help="Retrieval strategy used during eval (default: legacy; override with LEDGER_RETRIEVAL_MODE)",
    )
    eval_parser.add_argument(
        "--embed-backend",
        choices=EMBED_BACKENDS,
        default=resolve_embed_backend(None),
        help="Embedding backend for semantic_hybrid mode (default: local)",
    )
    eval_parser.add_argument(
        "--embed-model",
        default=None,
        help="Optional embedding model override for semantic_hybrid mode",
    )
    eval_parser.add_argument("--strict-cases", action="store_true", help="Fail when eval cases violate strict schema/path rules")
    eval_parser.add_argument("--baseline", help="Optional baseline metrics JSON path for regression check")
    eval_parser.add_argument("--write-baseline", dest="write_baseline", help="Write current metrics snapshot to JSON")

    args = parser.parse_args()

    def handle_listing_command(command_args):
        if command_args.command == "loops":
            if command_args.interactive:
                interactive_items(command_args, "loops", loop_status=command_args.status)
            elif command_args.verbose:
                verbose_items(command_args, "loops", loop_status=command_args.status)
            else:
                list_items(command_args, "loops", loop_status=command_args.status)
            return

        if command_args.command == "notes":
            if command_args.interactive:
                interactive_items(command_args, command_args.type)
            elif command_args.verbose:
                verbose_items(command_args, command_args.type)
            else:
                list_items(command_args, command_args.type)
            return

    command_handlers = {
        "query": handle_query_command,
        "discover-source": handle_discover_source_command,
        "eval": handle_eval_command,
    }
    embed_handlers = {
        "build": handle_embed_build_command,
        "status": handle_embed_status_command,
        "clean": handle_embed_clean_command,
    }

    try:
        if args.command in {"loops", "notes"}:
            handle_listing_command(args)
            return

        if args.command == "embed":
            embed_handler = embed_handlers.get(args.embed_command)
            if embed_handler is not None:
                embed_handler(args)
                return
            embed_parser.print_help()
            return

        handler = command_handlers.get(args.command)
        if handler is not None:
            handler(args)
            return
    except RuntimeError as exc:
        print(f"error: {exc}")
        raise SystemExit(2)

    parser.print_help()


if __name__ == "__main__":
    maybe_reexec_in_repo_venv()
    main()
