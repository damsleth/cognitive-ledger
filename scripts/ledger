_config = get_config()

NOTE_TYPES = {
    name: {"dir": _config.root_dir / info["dir"], "label": info["label"]}
    for name, info in _config.note_types.items()
}
CORE_NOTE_TYPES = _config.core_note_types
LOOP_STATUSES = _config.loop_statuses
QUERY_SCOPES = _config.query_scopes
