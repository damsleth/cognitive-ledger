# Cognitive Ledger configuration
# Values here are overridden by environment variables (LEDGER_ROOT_DIR, etc.)

# Paths (use ~ for home directory)
# root_dir: ~/Code/cognitive-ledger
notes_dir: ~/Code/cog-led/notes 
source_root: ~/Code/notes

# A/B eval corpus (used with: scripts/ledger_ab --corpus <path>)
# eval_corpus: ~/Code/my-ledger-instance

# Retrieval tuning
# retrieval_mode: legacy
# embed_backend: local
# embed_model: TaylorAI/bge-micro-v2

# Scoring weights (must sum to ~1.0)
# score_weight_bm25: 0.30
# score_weight_lexical: 0.15
# score_weight_tag: 0.15
# score_weight_scope: 0.15
# score_weight_recency: 0.15
# score_weight_confidence: 0.10

# Shortlisting
# shortlist_min_candidates: 24
# shortlist_max_candidates: 36
